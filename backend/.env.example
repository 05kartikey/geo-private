# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
CLIENT_ORIGIN=http://localhost:3001

# ── Auth ──────────────────────────────────────────────────────────────────────
API_KEY=dev-key

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# ── BLE ───────────────────────────────────────────────────────────────────────
BLE_SECRET=change-this-before-deploying
BLE_DEVICE_ID=esp32-geoprivate-01
BLE_SERVICE_UUID=12345678-1234-1234-1234-123456789abc
BLE_CHAR_UUID=abcdefab-cdef-abcd-efab-cdefabcdefab

# ── Circuit ───────────────────────────────────────────────────────────────────
CIRCUIT_LEVELS=5

# ── MongoDB (leave unset for in-memory fallback) ──────────────────────────────
# MONGO_URI=mongodb://localhost:27017/geoprivate

# ── Redis (leave unset for in-memory fallback) ────────────────────────────────
# REDIS_URL=redis://localhost:6379
